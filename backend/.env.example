# PowerWeChat 配置
# 复制此文件为 .env 并填写实际值

# ==================== 小程序配置（必填） ====================
WECHAT_APPID=wx1234567890abcdef
WECHAT_SECRET=your_app_secret_here

# ==================== 微信支付配置（可选） ====================
WECHAT_MCH_ID=1234567890
WECHAT_MCH_KEY=your_mch_api_v3_key_here
WECHAT_NOTIFY_URL=https://your-domain.com/api/wechat/pay/notify

# 小程序订阅消息模板ID（需要在小程序后台申请）
# WECHAT_SUBSCRIBE_TEMPLATE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
